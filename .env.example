# --- LLM / embeddings (local Ollama; both models are free) ---
# ollama pull gemma4:e4b && ollama pull embeddinggemma
OLLAMA_API_URL=http://localhost:11434
CATCHUP_LLM_MODEL=gemma4:e4b
CATCHUP_EMBED_MODEL=embeddinggemma

# --- Delivery (optional; stdout is used when unset) ---
SLACK_WEBHOOK_URL=

# --- Tuning (all optional) ---
# How many top items to deliver per run.
CATCHUP_TOP_N=10
# How many pre-ranked candidates get full LLM judging.
CATCHUP_JUDGE_CANDIDATES=30
# Digest language: ja / en
CATCHUP_LANG=ja
